# Default: ignore everything at the repo root.
/*

# Keep repository control files and the single public root doc.
!/.gitignore
!/README.md

# Public knowledge content.
!/TIL/
!/TIL/**
!/Templates/
!/Templates/**
!/Projects/
!/Projects/**
/Projects/Portfolio/
!/Archive/
/Archive/*
!/Archive/Projects/
!/Archive/Projects/**

# Never track local or nested-repo state.
.DS_Store
*.icloud
*.tmp
/TIL/.git
/TIL/.git/**
/TIL/.obsidian/
/TIL/.obsidian/**
/AGENTS.md
/PKM Guide.md
/AI/
/Areas/
/Inbox/
/Assets/
/Resources/
/.obsidian/
*.internal.md
